{
  extends: [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits",
    ":separateMajorReleases",
  ],
  labels: ["dependencies"],
  automergeType: "pr",
  platformAutomerge: true,
  prHourlyLimit: 0,
  prConcurrentLimit: 0,
  branchConcurrentLimit: 0,
  rebaseWhen: "behind-base-branch",
  packageRules: [
    {
      matchManagers: ["github-actions"],
      automerge: true,
    },
    {
      matchDatasources: ["docker"],
      matchUpdateTypes: ["minor", "patch", "digest"],
      automerge: true,
      addLabels: ["automerge"],
    },
  ],
  customManagers: [
    {
      customType: "regex",
      managerFilePatterns: ["/(^|/)charts\\/[^/]+\\/Chart\\.ya?ml$/"],
      matchStrings: [
        "# renovate: image=(?<depName>[^\\s]+)\\nappVersion: [\"']?(?<currentValue>[^\"'\\n]+)[\"']?",
      ],
      datasourceTemplate: "docker",
    },
    {
      customType: "regex",
      managerFilePatterns: ["/(^|/)charts\\/[^/]+\\/values\\.ya?ml$/"],
      matchStrings: [
        "# renovate: image=(?<depName>[^\\s]+)\\n\\s*(?:tag|version):\\s*[\"']?(?<currentValue>[^\"'\\n]+)[\"']?",
      ],
      datasourceTemplate: "docker",
    },
  ],
  postUpgradeTasks: {
    commands: [
      "./scripts/bump-chart.sh",
    ],
    fileFilters: [
      "charts/*/Chart.yaml",
    ],
    executionMode: "update",
  },
}
